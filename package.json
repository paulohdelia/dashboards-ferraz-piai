{
  "name": "dashboards-v4",
  "version": "1.0.0",
  "description": "Monorepo of V4 Company dashboards - Centralized SPA with Vue 3 + Vite + Pinia",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "keywords": ["dashboards", "vue", "vite", "express"],
  "author": "V4 Company",
  "license": "UNLICENSED",
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "express": "^4.18.3",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "vite": "^5.1.5",
    "@vitejs/plugin-vue": "^5.0.4",
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
  }
}
